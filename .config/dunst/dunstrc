[global]

monitor = 0
follow = mouse

width = 420
height = 300

origin = top-right
offset = 25x55

scale = 0

notification_limit = 8

progress_bar = true
progress_bar_height = 8
progress_bar_frame_width = 0

indicate_hidden = yes

transparency = 0

separator_height = 2
padding = 14
horizontal_padding = 16
text_icon_padding = 12

frame_width = 2
corner_radius = 12

gap_size = 10

sort = yes

font = FantasqueSansM Nerd Font Mono 10

line_height = 2

markup = full

format = "<b>%s</b>\n%b"

alignment = left
vertical_alignment = center

show_age_threshold = 60

word_wrap = yes

ellipsize = middle

ignore_newline = no

stack_duplicates = true
hide_duplicate_count = false

show_indicators = yes

icon_position = left

min_icon_size = 32
max_icon_size = 48

sticky_history = yes

history_length = 50

browser = firefox

always_run_script = true

title = Dunst

class = Dunst

[urgency_low]

background = "#171b24"
foreground = "#d6d2c4"
frame_color = "#384154"

timeout = 4

[urgency_normal]

background = "#171b24"
foreground = "#d6d2c4"
frame_color = "#b08d57"

timeout = 6

[urgency_critical]

background = "#171b24"
foreground = "#d6d2c4"
frame_color = "#a55d68"

timeout = 0

[fullscreen_delay_everything]

fullscreen = delay

[spotify]

appname = Spotify

format = "<b>Now Playing</b>\n%b"

[discord]

appname = Discord

format = "<b>Incoming Message</b>\n%b"

[volume]

summary = "Volume*"

background = "#171b24"
foreground = "#d6d2c4"
frame_color = "#7d9571"

[brightness]

summary = "Brightness*"

background = "#171b24"
foreground = "#d6d2c4"
frame_color = "#7d9571"

